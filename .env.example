# =============================================================================
# Fincept Terminal - example environment file.
#
# Copy to .env (gitignored) and fill in secrets.  NEVER commit .env.
#
# All variables match `Settings` fields in
# libs/fincept-core/src/fincept_core/config.py and are documented in
# spec/CONTRACTS.md §10.
#
# `pydantic-settings` is configured with `env_prefix="FINCEPT_"`, so every
# variable below is read from the environment as `FINCEPT_<NAME>`.
# =============================================================================

# --- Storage ----------------------------------------------------------------
FINCEPT_DB_URL=postgresql+asyncpg://fincept:fincept@localhost:5432/fincept
# 127.0.0.1 (not localhost) avoids a Windows IPv6 tarpit: 'localhost'
# resolves to ::1 first, but Memurai/Redis are typically bound to IPv4
# only, so the async client blocks waiting for an IPv6 connect that
# never succeeds.  Linux/macOS work either way.
FINCEPT_REDIS_URL=redis://127.0.0.1:6379/0

# --- Observability ----------------------------------------------------------
FINCEPT_OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4318
FINCEPT_LOG_LEVEL=INFO

# --- API auth (services/api) ------------------------------------------------
# HS256 JWT signing key for Bearer tokens.  Production deploys MUST override
# the dev default - see Settings.JWT_SECRET docstring.
FINCEPT_JWT_SECRET=dev-only-change-me

# --- Exchange / data secrets ------------------------------------------------
# Crypto market-data ingestion (read-only websocket; key not required for
# public depth/trades, included for forward-compat with private channels).
FINCEPT_BINANCE_API_KEY=
FINCEPT_BINANCE_API_SECRET=

# Polygon (alt provider for equity bars; falls back to yfinance when unset).
FINCEPT_POLYGON_API_KEY=

# LLM providers (Phase X agents).
FINCEPT_OPENAI_API_KEY=
FINCEPT_ANTHROPIC_API_KEY=

# --- Alpaca (primary brokerage) ---------------------------------------------
# Paper key+secret from Alpaca dashboard.  ALPACA_BASE_URL controls
# paper vs live; switching to live requires explicit operator action and
# satisfies Gate 5.
#   Paper: https://paper-api.alpaca.markets    (DEFAULT)
#   Live:  https://api.alpaca.markets
FINCEPT_ALPACA_API_KEY=
FINCEPT_ALPACA_API_SECRET=
FINCEPT_ALPACA_BASE_URL=https://paper-api.alpaca.markets

# --- Trading behavior -------------------------------------------------------
# `paper` keeps the system isolated from real venues; `live` requires Gate 5.
FINCEPT_TRADING_MODE=paper

# OMS routing.  `sim` keeps everything in-process via the PaperFiller; `alpaca`
# submits OrderIntents to Alpaca's REST API and tails their order status.
# `alpaca` requires both ALPACA_API_KEY and ALPACA_API_SECRET above.
FINCEPT_OMS_ROUTER=sim

# Universe (comma-separated canonical symbols).
FINCEPT_UNIVERSE=BTC-USD,ETH-USD,SOL-USD

# Default venue for new strategies that don't specify one.
FINCEPT_DEFAULT_VENUE=binance

# --- Risk limits (USD) ------------------------------------------------------
FINCEPT_MAX_NOTIONAL_USD_PER_SYMBOL=10000
FINCEPT_MAX_GROSS_NOTIONAL_USD=50000
FINCEPT_MAX_DAILY_LOSS_USD=2000
