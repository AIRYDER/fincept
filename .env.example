# =============================================================================
# Fincept Terminal — example environment.
# Copy to .env and fill secrets. NEVER commit .env.
# All keys are documented in spec/CONTRACTS.md §10.
# =============================================================================

# --- Storage ---------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://fincept:fincept@localhost:5432/fincept
REDIS_URL=redis://localhost:6379/0

# --- Observability ---------------------------------------------------------
# Leave OTEL endpoint blank in local dev to disable export.
OTEL_EXPORTER_OTLP_ENDPOINT=
LOG_LEVEL=INFO

# --- Auth (services/api) ---------------------------------------------------
JWT_SECRET=dev-only-change-me

# --- Secrets (NEVER logged; loaded into Settings as Optional) --------------
BINANCE_API_KEY=
BINANCE_API_SECRET=
COINBASE_API_KEY=
COINBASE_API_SECRET=
KRAKEN_API_KEY=
KRAKEN_API_SECRET=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
POLYGON_API_KEY=

# --- Behavior --------------------------------------------------------------
# paper | live  --  paper-only until ROADMAP Gate 5 passes.
TRADING_MODE=paper
UNIVERSE=BTC-USD,ETH-USD,SOL-USD
DEFAULT_VENUE=binance

# --- Risk limits (USD) -----------------------------------------------------
MAX_NOTIONAL_USD_PER_SYMBOL=10000
MAX_GROSS_NOTIONAL_USD=50000
MAX_DAILY_LOSS_USD=2000
