# Backend API base URL (FastAPI from services/api).
NEXT_PUBLIC_API_URL=http://localhost:8010

# WebSocket URL.  Defaults to NEXT_PUBLIC_API_URL with ws:// scheme if unset.
NEXT_PUBLIC_WS_URL=ws://localhost:8010

# Default strategy id surfaced on the home page.  Optional.
NEXT_PUBLIC_DEFAULT_STRATEGY=orchestrator.v1

# Server-only portfolio report provider keys. Do not prefix these with NEXT_PUBLIC.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_PORTFOLIO_MODEL=gpt-5.5
ANTHROPIC_PORTFOLIO_MODEL=claude-opus-4-7
OPENAI_PORTFOLIO_REASONING_EFFORT=high
ANTHROPIC_PORTFOLIO_THINKING_EFFORT=high
PORTFOLIO_REPORT_MAX_OUTPUT_TOKENS=6000
