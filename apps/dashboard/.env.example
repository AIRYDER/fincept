# Backend API base URL (FastAPI from services/api).
NEXT_PUBLIC_API_URL=http://localhost:8000

# WebSocket URL.  Defaults to NEXT_PUBLIC_API_URL with ws:// scheme if unset.
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# Default strategy id surfaced on the home page.  Optional.
NEXT_PUBLIC_DEFAULT_STRATEGY=orchestrator.v1
