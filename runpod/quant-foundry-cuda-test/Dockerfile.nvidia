# Fallback CUDA test image using nvidia/cuda base (RunPod recommended approach).
#
# If runpod/base also fails, try this. It uses the bare nvidia/cuda runtime
# image and installs Python manually, which is what RunPod's own docs
# recommend for GPU serverless workers.
#
# Build (from repo root):
#   DOCKER_BUILDKIT=1 docker build \
#     -t fincept-qf-cuda-test-nvidia \
#     -f runpod/quant-foundry-cuda-test/Dockerfile.nvidia \
#     --build-arg GIT_SHA=$(git rev-parse HEAD) .

FROM nvidia/cuda:12.4.1-runtime-ubuntu22.04

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    PIP_NO_CACHE_DIR=1 \
    DEBIAN_FRONTEND=noninteractive

WORKDIR /worker

RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 python3-pip python3-venv \
    && ln -sf /usr/bin/python3 /usr/bin/python \
    && rm -rf /var/lib/apt/lists/*

RUN pip3 install --no-cache-dir "runpod==1.7.13"

COPY runpod/quant-foundry-cuda-test/handler.py /worker/handler.py

ARG GIT_SHA=unknown
ENV QUANT_FOUNDRY_GIT_SHA=${GIT_SHA} \
    PYTHONPATH=/worker

ENTRYPOINT ["python", "-u", "/worker/handler.py"]
